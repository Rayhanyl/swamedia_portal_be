# Build artifacts — regenerated by `bal build` inside the image.
target/
generated/

# Local secrets — never baked into the image, only mounted at runtime.
Config.toml
Config.docker.toml

# VCS / editor / docs — irrelevant to the build, only bloat the build context.
.git/
.gitignore
.vscode/
.idea/
documentation/
*.md

# Docker files themselves don't need to be in the build context copy.
Dockerfile
docker-compose.yml
.dockerignore
